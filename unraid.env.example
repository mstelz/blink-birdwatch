# Copy to .env for docker-compose.unraid.yml
# This file is organized by container/service.

# =========================
# Global / shared
# =========================
TZ=America/Chicago

# =========================
# birdwatch (Blink -> clips -> WAV bridge)
# =========================
# Internal port inside container
PORT=8787
# Host port mapping
BRIDGE_PORT=8787

# Bridge fetch loop
BLINK_POLL_INTERVAL_SEC=180
BLINK_FETCH_COMMAND=python3 /app/bin/blink_fetch.py

# blink_fetch.py mode: download (recommended) or metadata
BLINK_FETCH_MODE=download
# How many metadata records to fetch per poll
BLINK_FETCH_META_STOP=200

# Where to store downloaded MP4 clips (inside container)
BLINK_DOWNLOAD_DIR=/app/work/blink-downloads

# Bridge state / dedupe
SEEN_IDS_FILE=/app/work/.seen-motion-ids.json
MAX_SEEN_IDS=10000

# Blink auth/state storage (inside container)
BLINK_AUTH_FILE=/app/config/blink-auth.json
BLINK_FETCH_STATE_FILE=/app/config/blink-fetch-state.json

# Optional filter: comma-separated camera names
BLINK_CAMERA_NAMES=
BLINK_FETCH_MAX_EVENTS=25
# For one-shot testing/replay, you can temporarily set both to 1 to re-emit recent clips
# without advancing the saved cursor. Useful when RTSP needs source MP4s immediately.
BLINK_FETCH_IGNORE_SEEN=0
BLINK_FETCH_NO_SAVE_STATE=0

# Host mounts (set these to your Unraid shares)
BLINK_CONFIG_DIR=/mnt/user/appdata/blink-bridge/config
BLINK_WORK_DIR=/mnt/user/blink-bridge

# Where the bridge drops WAV files for BirdNET-Go worker/UI to consume
BIRDNET_WATCH_DIR=/mnt/user/blink-bridge/output

# Integrated RTSP publisher settings (runs inside the birdwatch container)
ENABLE_RTSP_PUBLISHER=1
RTSP_POLL_SEC=5
RTSP_GLOB_PATTERN=*.mp4
RTSP_TRANSPORT=tcp
RTSP_STREAM_PREFIX=
RTSP_VIDEO_FPS=15
RTSP_H264_PRESET=veryfast
RTSP_H264_CRF=23
RTSP_MJPEG_Q=2
# 0 means "effectively endless until replaced by a newer clip".
RTSP_STILL_HOLD_SEC=0
# Regex must contain (?P<camera>...) group. Note: the integrated startup path currently forces
# the known-good default below to avoid startup env mangling seen in some deployments.
RTSP_CAMERA_REGEX=^(?P<camera>.+)-\d{4}-.*\.mp4$

# Persist MP4s for RTSP publishing.
# When BLINK_FETCH_MODE=metadata, the bridge downloads MP4s transiently. Set PERSIST_MP4=1
# to save a copy into PERSIST_MP4_DIR (defaults to BLINK_DOWNLOAD_DIR).
# In download mode, the bridge will reuse the original camera-named file when possible instead of
# making a duplicate download-*.mp4 copy.
PERSIST_MP4=0
PERSIST_MP4_DIR=/app/work/blink-downloads
# Rarely needed: force a second persisted copy even when localFile already matches the desired
# camera-named filename in PERSIST_MP4_DIR.
PERSIST_EXISTING_LOCAL_MP4=0
# Set to 0 for RTSP-only mode to skip MP4 -> WAV extraction entirely.
GENERATE_WAV=1
# Optional storage control: after processing succeeds, remove older MP4s for the same camera
# and keep only the newest clip in PERSIST_MP4_DIR.
PRUNE_OLD_MP4=0

# =========================
# birdnet-go-ui (UI/API)
# =========================
BIRDNET_GO_PORT=8080
BIRDNET_UID=99
BIRDNET_GID=100

BIRDNET_CONFIG_DIR=/mnt/user/appdata/birdnet-go/config
BIRDNET_DATA_DIR=/mnt/user/appdata/birdnet-go/data

# Where birdnet-go worker writes CSV outputs
BIRDNET_RESULT_DIR=/mnt/user/blink-bridge/birdnet-output

# =========================
# birdnet-go-worker (optional; disabled by default via compose profile "worker")
# =========================
# For testing you may want more detections:
# BIRDNET_THRESHOLD=0.2  (not currently wired; edit compose command to add -t)

# =========================
# db-importer (CSV -> SQLite) sidecar
# =========================
BIRDNET_IMPORTER_TAG=v0.1.26
IMPORT_INTERVAL_SEC=10

# =========================
# mediamtx (RTSP server)
# =========================
MEDIA_MTX_RTSP_PORT=8554

