# Copy to .env (or map in Unraid template)
PORT=8787
# Used by docker-compose host mapping; ignored by standalone Unraid template
BRIDGE_PORT=8787
POLL_INTERVAL_SEC=180
BLINK_EVENTS_FILE=/app/config/blink-events.json
WORK_DIR=/app/work

# Where to drop WAV files for BirdNET-Go to process
BIRDNET_GO_INPUT_DIR=/app/output

# Optional Blink pull mode
BLINK_POLL_INTERVAL_SEC=180
BRIDGE_URL=http://127.0.0.1:8787/bridge/blink/event
BLINK_FETCH_COMMAND=python3 /app/bin/blink_fetch.py

# Blink authentication (used by blink_fetch.py)
BLINK_USERNAME=
BLINK_PASSWORD=
# One-time MFA code from email when prompted; clear after first successful auth
BLINK_2FA_CODE=
BLINK_AUTH_FILE=/app/config/blink-auth.json
BLINK_FETCH_STATE_FILE=/app/config/blink-fetch-state.json
BLINK_CAMERA_NAMES=
BLINK_FETCH_MAX_EVENTS=25

# Companion BirdNET-Go settings (for compose-based installs)
TZ=America/Chicago
BIRDNET_GO_PORT=8080
BIRDNET_UID=99
BIRDNET_GID=100

# Host paths (set these to your Unraid shares)
BIRDNET_CONFIG_DIR=./birdnet-go/config
BIRDNET_DATA_DIR=./birdnet-go/data
BIRDNET_OUTPUT_DIR=./output
BLINK_CONFIG_DIR=./config
BLINK_WORK_DIR=./work
