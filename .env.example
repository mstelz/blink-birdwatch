PORT=8787
POLL_INTERVAL_SEC=180
BLINK_EVENTS_FILE=./config/blink-events.json
WORK_DIR=./work

# Where to drop WAV files for BirdNET-Go to process
BIRDNET_GO_INPUT_DIR=/app/output

# Blink bridge/poller
BLINK_POLL_INTERVAL_SEC=180
BRIDGE_URL=http://127.0.0.1:8787/bridge/blink/event
BLINK_FETCH_COMMAND=python3 /app/bin/blink_fetch.py
BLINK_DOWNLOAD_DIR=/app/work/blink-downloads

# Blink authentication/state storage
# Configure credentials via: docker exec -it blink-bridge blink login
BLINK_DB_FILE=/app/config/blink-bridge.db
BLINK_AUTH_FILE=/app/config/blink-auth.json
BLINK_FETCH_STATE_FILE=/app/config/blink-fetch-state.json
# Optional comma-separated list of camera names, e.g. "Bird Feeder,Backyard"
BLINK_CAMERA_NAMES=
BLINK_FETCH_MAX_EVENTS=25

# Timezone (passed to BirdNET-Go container)
TZ=America/Chicago

# Host ports
BIRDNET_GO_PORT=8080
BRIDGE_PORT=8787
